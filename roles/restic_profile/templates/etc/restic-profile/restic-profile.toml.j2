{# jinja2: lstrip_blocks: True, trim_blocks: True #}
# /etc/restic-profile/restic-profile.toml
# Generated by Ansible — do not edit manually

{% macro render_managed_hook_paths(profile_name, phase, script_srcs, template_srcs) -%}
{% for _ignored in script_srcs -%}
  "{{ restic_profile_hooks_dir }}/restic-profile-{{ profile_name }}.{{ phase }}-{{ '%02d' | format(loop.index) }}.sh",
{% endfor -%}
{% set _script_count = script_srcs | length %}
{% for _ignored in template_srcs -%}
  "{{ restic_profile_hooks_dir }}/restic-profile-{{ profile_name }}.{{ phase }}-{{ '%02d' | format(_script_count + loop.index) }}.sh",
{% endfor -%}
{%- endmacro %}

[global]
restic_binary = "{{ restic_profile_restic_binary | default('') }}"
no_cache = {{ restic_profile_no_cache | default(false) | ansible.builtin.bool | lower }}
retry_lock = "{{ restic_profile_retry_lock }}"

{% for profile_name, profile in restic_profile_profiles.items() %}
{% set _profile_enabled = profile.enabled | default(true) | ansible.builtin.bool %}
{% if _profile_enabled %}
[profiles.{{ profile_name }}]
# --- Repository ---
repository = "{{ profile.repository }}"
password   = "{{ profile.password }}"
{% if profile.rest_username | default('') != '' %}
# REST backend auth (restic >= 0.16.1)
rest_username = "{{ profile.rest_username }}"
rest_password = "{{ profile.rest_password }}"
{% endif %}
{% if profile.cacert | default('') != '' %}
cacert = "{{ profile.cacert }}"
{% endif %}
{% if profile.aws_access_key_id | default('') != '' %}
# S3-compatible backend credentials
aws_default_region    = "{{ profile.aws_default_region | default('') }}"
aws_access_key_id     = "{{ profile.aws_access_key_id }}"
aws_secret_access_key = "{{ profile.aws_secret_access_key }}"
{% endif %}
{% if profile.google_project_id | default('') != '' %}
# Google Cloud Storage credentials
google_project_id              = "{{ profile.google_project_id }}"
google_application_credentials = "{{ profile.google_application_credentials | default('') }}"
google_access_token            = "{{ profile.google_access_token | default('') }}"
{% endif %}

# --- Backup settings ---
sources = [
{% for source in profile.sources | default([]) %}
  "{{ source }}",
{% endfor %}
]
tag = "{{ profile.tag | default(profile_name) }}"
# Inline exclude patterns — each is passed as --exclude to restic backup.
# For large exclude lists, use exclude_file_content instead (see below).
exclude_patterns = [
{% for pattern in profile.exclude_patterns | default([]) %}
  "{{ pattern }}",
{% endfor %}
]
{% if profile.exclude_file_content | default('') | length > 0 %}
# Path to a per-profile exclude file rendered by Ansible from exclude_file_content.
# Passed as --exclude-file to restic backup; supplements exclude_patterns.
exclude_file = "{{ restic_profile_config_dir }}/restic-profile-{{ profile_name }}.exclude"
{% endif %}
one_file_system = {{ profile.one_file_system | default(false) | ansible.builtin.bool | lower }}
forget = {{ profile.forget | default(true) | ansible.builtin.bool | lower }}
forget_current_host = {{ profile.forget_current_host | default(false) | ansible.builtin.bool | lower }}
prune = {{ profile.prune | default(false) | ansible.builtin.bool | lower }}

# --- Retention policy ---
keep_last    = {{ profile.keep_last    | default(0) | int }}
keep_hourly  = {{ profile.keep_hourly  | default(6) | int }}
keep_daily   = {{ profile.keep_daily   | default(7) | int }}
keep_weekly  = {{ profile.keep_weekly  | default(4) | int }}
keep_monthly = {{ profile.keep_monthly | default(3) | int }}
keep_yearly  = {{ profile.keep_yearly  | default(0) | int }}

# --- Schedule (consumed by Ansible to render systemd timer; not used by the CLI) ---
on_calendar          = "{{ profile.on_calendar          | default('hourly') }}"
randomized_delay_sec = "{{ profile.randomized_delay_sec | default('10min') }}"

# --- Runtime ---
system_user = "{{ profile.system_user | default('root') }}"
{% if profile.restic_binary is defined %}
restic_binary = "{{ profile.restic_binary }}"
{% endif %}
{% if profile.no_cache is defined %}
no_cache    = {{ profile.no_cache | ansible.builtin.bool | lower }}
{% endif %}
retry_lock  = "{{ profile.retry_lock  | default('') }}"

{% set _hooks = profile.hooks | default({}) %}
{% set _hook_phases = restic_profile_hook_phases %}
{% set _hooks_shell = _hooks.shell | default('/bin/sh') %}
{% set _has_hook_cmds = namespace(v=false) %}

{% for _phase in _hook_phases %}
{% set _phase_commands = _hooks.get(_phase, []) %}
{% set _phase_scripts = _hooks.get(_phase ~ '_scripts', []) %}
{% set _phase_templates = _hooks.get(_phase ~ '_templates', []) %}
{% if _phase_commands | length > 0 or _phase_scripts | length > 0 or _phase_templates | length > 0 %}
{% set _has_hook_cmds.v = true %}
{% endif %}
{% endfor %}

{% if _has_hook_cmds.v or _hooks_shell != '/bin/sh' %}
[profiles.{{ profile_name }}.hooks]
shell = "{{ _hooks_shell }}"

{% for _phase in _hook_phases %}
{% set _phase_commands = _hooks.get(_phase, []) %}
{% set _phase_scripts = _hooks.get(_phase ~ '_scripts', []) %}
{% set _phase_templates = _hooks.get(_phase ~ '_templates', []) %}
{% if _phase_commands | length > 0 or _phase_scripts | length > 0 or _phase_templates | length > 0 %}
{{ _phase }} = [
{% for _cmd in _phase_commands %}
  {{ _cmd | tojson }},
{% endfor %}
{{ render_managed_hook_paths(profile_name, _phase, _phase_scripts, _phase_templates) }}
]
{% endif %}
{% endfor %}

{% endif %}
{% endif %}
{% endfor %}
