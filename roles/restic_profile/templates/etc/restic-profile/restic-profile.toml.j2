{# jinja2: lstrip_blocks: True, trim_blocks: True #}
# /etc/restic-profile/restic-profile.toml
# Generated by Ansible — do not edit manually

{% macro render_managed_hook_paths(profile_name, phase, script_srcs, template_srcs) -%}
{% for _src in script_srcs -%}
{% set _basename = _src | basename -%}
{% set _ext = '.' ~ (_basename.split('.') | last) if '.' in _basename else '.sh' %}
  "{{ restic_profile_hooks_dir }}/restic-profile-{{ profile_name }}.{{ phase }}-{{ '%02d' | format(loop.index) }}{{ _ext }}",
{% endfor -%}
{% set _script_count = script_srcs | length %}
{% for _src in template_srcs -%}
{% set _basename = (_src | basename) | replace('.j2', '') -%}
{% set _ext = '.' ~ (_basename.split('.') | last) if '.' in _basename else '.sh' %}
  "{{ restic_profile_hooks_dir }}/restic-profile-{{ profile_name }}.{{ phase }}-{{ '%02d' | format(_script_count + loop.index) }}{{ _ext }}",
{% endfor -%}
{%- endmacro %}
[global]
restic_binary = "{{ restic_profile_restic_binary | default('') }}"
no_cache = {{ restic_profile_no_cache | default(false) | ansible.builtin.bool | lower }}
retry_lock = "{{ restic_profile_retry_lock }}"
unlock = {{ restic_profile_unlock | default(false) | ansible.builtin.bool | lower }}

# --- Repositories ---
{% for rname, r in restic_profile_repositories.items() %}
[repositories.{{ rname }}]
repository = "{{ r.repository }}"
password   = "{{ r.password }}"
{% if r.rest_username | default('') != '' %}
# REST backend auth (restic >= 0.16.1)
rest_username = "{{ r.rest_username }}"
rest_password = "{{ r.rest_password }}"
{% endif %}
{% if r.cacert | default('') != '' %}
cacert = "{{ r.cacert }}"
{% endif %}
{% if r.aws_access_key_id | default('') != '' %}
# S3-compatible backend credentials
aws_default_region    = "{{ r.aws_default_region | default('') }}"
aws_access_key_id     = "{{ r.aws_access_key_id }}"
aws_secret_access_key = "{{ r.aws_secret_access_key }}"
{% endif %}
{% if r.google_project_id | default('') != '' %}
# Google Cloud Storage credentials
google_project_id              = "{{ r.google_project_id }}"
google_application_credentials = "{{ r.google_application_credentials | default('') }}"
google_access_token            = "{{ r.google_access_token | default('') }}"
{% endif %}

{% endfor %}
# --- Profiles ---
{% for pname, profile in restic_profile_profiles.items() %}
{% set _profile_enabled = profile.enabled | default(true) | ansible.builtin.bool %}
{% if _profile_enabled %}
[profiles.{{ pname }}]
repository_ref = "{{ profile.repository_ref }}"
{% if profile.tag is defined or (profile.tag | default('')) != '' %}
tag = "{{ profile.tag }}"
{% endif %}
{% if profile.on_calendar is defined %}
on_calendar = "{{ profile.on_calendar }}"
{% endif %}
{% if profile.randomized_delay_sec is defined %}
randomized_delay_sec = "{{ profile.randomized_delay_sec }}"
{% endif %}
{% if profile.restic_binary is defined %}
restic_binary = "{{ profile.restic_binary }}"
{% endif %}
{% if profile.no_cache is defined %}
no_cache = {{ profile.no_cache | ansible.builtin.bool | lower }}
{% endif %}
{% if profile.retry_lock is defined %}
retry_lock = "{{ profile.retry_lock }}"
{% endif %}
{% if profile.unlock is defined %}
unlock = {{ profile.unlock | ansible.builtin.bool | lower }}
{% endif %}

{% if profile.backup is defined %}
[profiles.{{ pname }}.backup]
sources = [
{% for source in profile.backup.sources | default([]) %}
  "{{ source }}",
{% endfor %}
]
{% if profile.backup.exclude_patterns is defined %}
exclude_patterns = [
{% for pattern in profile.backup.exclude_patterns | default([]) %}
  "{{ pattern }}",
{% endfor %}
]
{% endif %}
{% if profile.backup.exclude_file_content | default('') | length > 0 %}
exclude_file = "{{ restic_profile_config_dir }}/restic-profile-{{ pname }}.exclude"
{% endif %}
{% if profile.backup.one_file_system is defined %}
one_file_system = {{ profile.backup.one_file_system | ansible.builtin.bool | lower }}
{% endif %}
{% endif %}

{% if profile.retention is defined %}
[profiles.{{ pname }}.retention]
keep_last = {{ profile.retention.keep_last | default(0) | int }}
keep_hourly = {{ profile.retention.keep_hourly | default(0) | int }}
keep_daily = {{ profile.retention.keep_daily | default(0) | int }}
keep_weekly = {{ profile.retention.keep_weekly | default(0) | int }}
keep_monthly = {{ profile.retention.keep_monthly | default(0) | int }}
keep_yearly = {{ profile.retention.keep_yearly | default(0) | int }}
{% if profile.retention.prune is defined %}
prune = {{ profile.retention.prune | ansible.builtin.bool | lower }}
{% endif %}
{% if profile.retention.forget_current_host is defined %}
forget_current_host = {{ profile.retention.forget_current_host | ansible.builtin.bool | lower }}
{% endif %}
{% endif %}

{% set _hooks = profile.hooks | default({}) %}
{% set _hook_phases = restic_profile_hook_phases %}
{% set _hooks_shell = _hooks.shell | default('/bin/sh') %}
{% set _has_hook_cmds = namespace(v=false) %}
{% for _phase in _hook_phases %}
{% set _phase_commands = _hooks.get(_phase, []) %}
{% set _phase_scripts = _hooks.get(_phase ~ '_scripts', []) %}
{% set _phase_templates = _hooks.get(_phase ~ '_templates', []) %}
{% if _phase_commands | length > 0 or _phase_scripts | length > 0 or _phase_templates | length > 0 %}
{% set _has_hook_cmds.v = true %}
{% endif %}
{% endfor %}
{% if _has_hook_cmds.v or _hooks_shell != '/bin/sh' %}
[profiles.{{ pname }}.hooks]
shell = "{{ _hooks_shell }}"

{% for _phase in _hook_phases %}
{% set _phase_commands = _hooks.get(_phase, []) %}
{% set _phase_scripts = _hooks.get(_phase ~ '_scripts', []) %}
{% set _phase_templates = _hooks.get(_phase ~ '_templates', []) %}
{% if _phase_commands | length > 0 or _phase_scripts | length > 0 or _phase_templates | length > 0 %}
{{ _phase }} = [
{% for _cmd in _phase_commands %}
  {{ _cmd | tojson }},
{% endfor %}
{% if _phase_scripts | length > 0 or _phase_templates | length > 0 %}
{{ render_managed_hook_paths(pname, _phase, _phase_scripts, _phase_templates) -}}
{% endif %}
]
{% endif %}
{% endfor %}
{% endif %}
{% endif %}

{% endfor %}
