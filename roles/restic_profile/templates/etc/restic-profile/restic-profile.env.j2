{# jinja2: lstrip_blocks: True, trim_blocks: True #}
{% set _profile_name = _profile_item.key %}
{% set _profile = _profile_item.value %}
{% set _restic_binary = _profile.restic_binary if _profile.restic_binary is defined else restic_profile_restic_binary | default('') %}
# Generated by Ansible — do not edit manually
# shellcheck disable=SC1090
# source "{{ restic_profile_config_dir }}/restic-profile-{{ _profile_name }}.env"

# Helper metadata for /usr/local/bin/restic.sh
export RESTIC_PROFILE_NAME={{ _profile_name | quote }}
export RESTIC_PROFILE_RESTIC_BINARY={{ _restic_binary | quote }}

export RESTIC_REPOSITORY={{ _profile.repository | quote }}
export RESTIC_PASSWORD={{ _profile.password | quote }}
{% if _profile.rest_username | default('') != '' %}

# REST backend auth (restic >= 0.16.1)
export RESTIC_REST_USERNAME={{ _profile.rest_username | quote }}
export RESTIC_REST_PASSWORD={{ _profile.rest_password | quote }}
{% endif %}
{% if _profile.cacert | default('') != '' %}

export RESTIC_CACERT={{ _profile.cacert | quote }}
{% endif %}
{% if _profile.aws_access_key_id | default('') != '' %}

# S3-compatible backend credentials
export AWS_DEFAULT_REGION={{ _profile.aws_default_region | quote }}
export AWS_ACCESS_KEY_ID={{ _profile.aws_access_key_id | quote }}
export AWS_SECRET_ACCESS_KEY={{ _profile.aws_secret_access_key | quote }}
{% endif %}
{% if _profile.google_project_id | default('') != '' %}

# Google Cloud Storage credentials
export GOOGLE_PROJECT_ID={{ _profile.google_project_id | quote }}
{% if _profile.google_access_token | default('') != '' %}
export GOOGLE_ACCESS_TOKEN={{ _profile.google_access_token | quote }}
{% elif _profile.google_application_credentials | default('') != '' %}
export GOOGLE_APPLICATION_CREDENTIALS={{ _profile.google_application_credentials | quote }}
{% endif %}
{% endif %}
