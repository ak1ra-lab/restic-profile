{# jinja2: lstrip_blocks: True, trim_blocks: True #}
{% set _profile_name = _profile_item.key %}
{% set _profile = _profile_item.value %}
# Generated by Ansible — do not edit manually
# export $(grep -v '^#' "{{ restic_profile_config_dir }}/restic-profile-{{ _profile_name }}.env" | xargs)

export RESTIC_REPOSITORY="{{ _profile.repository }}"
export RESTIC_PASSWORD="{{ _profile.password }}"
{% if _profile.rest_username | default('') != '' %}

# REST backend auth (restic >= 0.16.1)
export RESTIC_REST_USERNAME="{{ _profile.rest_username }}"
export RESTIC_REST_PASSWORD="{{ _profile.rest_password }}"
{% endif %}
{% if _profile.cacert | default('') != '' %}

export RESTIC_CACERT="{{ _profile.cacert }}"
{% endif %}
{% if _profile.aws_access_key_id | default('') != '' %}

# S3-compatible backend credentials
export AWS_DEFAULT_REGION="{{ _profile.aws_default_region }}"
export AWS_ACCESS_KEY_ID="{{ _profile.aws_access_key_id }}"
export AWS_SECRET_ACCESS_KEY="{{ _profile.aws_secret_access_key }}"
{% endif %}
{% if _profile.google_project_id | default('') != '' %}

# Google Cloud Storage credentials
export GOOGLE_PROJECT_ID="{{ _profile.google_project_id }}"
{% if _profile.google_access_token | default('') != '' %}
export GOOGLE_ACCESS_TOKEN="{{ _profile.google_access_token }}"
{% elif _profile.google_application_credentials | default('') != '' %}
export GOOGLE_APPLICATION_CREDENTIALS="{{ _profile.google_application_credentials }}"
{% endif %}
{% endif %}
