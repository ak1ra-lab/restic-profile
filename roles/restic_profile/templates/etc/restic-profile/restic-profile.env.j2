{# jinja2: lstrip_blocks: True, trim_blocks: True #}
{% set _profile_name = _profile_item.key %}
{% set _profile = _profile_item.value %}
{% set _repo_ref = _profile.repository_ref %}
{% set _repo = restic_profile_repositories[_repo_ref] | default({}) %}
{% set _restic_binary = _profile.restic_binary if _profile.restic_binary is defined else restic_profile_restic_binary | default('') %}
# Generated by Ansible — do not edit manually
# Source this file in a Bash shell when you need direct restic access:
#   source "{{ restic_profile_config_dir }}/restic-profile-{{ _profile_name }}.env"

# Profile metadata for direct shell sourcing
export RESTIC_PROFILE_NAME={{ _profile_name | quote }}
export RESTIC_PROFILE_RESTIC_BINARY={{ _restic_binary | quote }}

export RESTIC_REPOSITORY={{ _repo.repository | default('') | quote }}
export RESTIC_PASSWORD={{ _repo.password | default('') | quote }}
{% if _repo.rest_username | default('') != '' %}

# REST backend auth (restic >= 0.16.1)
export RESTIC_REST_USERNAME={{ _repo.rest_username | quote }}
export RESTIC_REST_PASSWORD={{ _repo.rest_password | quote }}
{% endif %}
{% if _repo.cacert | default('') != '' %}

export RESTIC_CACERT={{ _repo.cacert | quote }}
{% endif %}
{% if _repo.aws_access_key_id | default('') != '' %}

# S3-compatible backend credentials
export AWS_DEFAULT_REGION={{ _repo.aws_default_region | default('') | quote }}
export AWS_ACCESS_KEY_ID={{ _repo.aws_access_key_id | quote }}
export AWS_SECRET_ACCESS_KEY={{ _repo.aws_secret_access_key | quote }}
{% endif %}
{% if _repo.google_project_id | default('') != '' %}

# Google Cloud Storage credentials
export GOOGLE_PROJECT_ID={{ _repo.google_project_id | quote }}
{% if _repo.google_access_token | default('') != '' %}
export GOOGLE_ACCESS_TOKEN={{ _repo.google_access_token | quote }}
{% elif _repo.google_application_credentials | default('') != '' %}
export GOOGLE_APPLICATION_CREDENTIALS={{ _repo.google_application_credentials | quote }}
{% endif %}
{% endif %}
