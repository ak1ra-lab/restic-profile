{# jinja2: lstrip_blocks: True, trim_blocks: True #}
{% set _profile_name = _profile_item.key %}
{% set _profile = _profile_item.value %}
{% set _is_backup = (_profile.sources | default([]) | length) > 0 %}
{% set _cmd = "backup" if _is_backup else "forget" %}
{% set _unit_prefix = restic_profile_backup_unit_prefix if _is_backup else restic_profile_forget_unit_prefix %}
{% set _cpu_quota = _profile.cpu_quota if _profile.cpu_quota is defined else restic_profile_systemd_cpu_quota | default('') %}
{% set _nice = _profile.nice if _profile.nice is defined else restic_profile_systemd_nice | default('') %}
{% set _io_class = _profile.io_scheduling_class if _profile.io_scheduling_class is defined else restic_profile_systemd_io_scheduling_class | default('') %}
{% set _io_priority = _profile.io_scheduling_priority if _profile.io_scheduling_priority is defined else restic_profile_systemd_io_scheduling_priority | default('') %}
# {{ _unit_prefix }}{{ _profile_name }}.service
# Generated by Ansible — do not edit manually

[Unit]
Description=Restic {{ _cmd }} — {{ _profile_name }}
# Soft dependency: start after network is up, but don't require it
# (local-only repositories work without a network connection)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
{% if _profile.system_user | default('root') != 'root' %}
User={{ _profile.system_user }}
{% endif %}
{% if _cpu_quota != '' %}
CPUQuota={{ _cpu_quota }}
{% endif %}
{% if _nice != '' %}
Nice={{ _nice }}
{% endif %}
{% if _io_class != '' %}
IOSchedulingClass={{ _io_class }}
{% if _io_priority != '' %}
IOSchedulingPriority={{ _io_priority }}
{% endif %}
{% endif %}
ExecStart={{ restic_profile_bin }} {{ _cmd }} {{ _profile_name }} \
    --config {{ restic_profile_config_file }}
# Let systemd capture stdout/stderr in the journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier={{ _unit_prefix }}{{ _profile_name }}

[Install]
WantedBy=multi-user.target
