# /etc/default/restic-rest-server
# Generated by Ansible — do not edit manually

# TCP or UNIX listen address.
#LISTEN=unix:/run/restic-rest-server
LISTEN={{ restic_rest_server_listen }}

# Directory to store backups.
# Note: the server will not start unless this variable is defined.
BACKUP_DIR={{ restic_rest_server_backup_dir }}

# Extra arguments passed to restic-rest-server.
ARGS="\
{% if restic_rest_server_append_only %}
  --append-only \
{% endif %}
{% if restic_rest_server_private_repos %}
  --private-repos \
{% endif %}
  --htpasswd-file {{ restic_rest_server_htpasswd_file }} \
{% if restic_rest_server_extra_args | default('') != '' %}
  {{ restic_rest_server_extra_args }} \
{% endif %}
"
